{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "apps/web/src/ui", "apps/web/dist-web"]
}
