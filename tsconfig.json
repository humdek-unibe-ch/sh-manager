{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shm/schemas": ["packages/schemas/src/index.ts"],
      "@shm/registry": ["packages/registry/src/index.ts"],
      "@shm/resolver": ["packages/resolver/src/index.ts"],
      "@shm/docker": ["packages/docker/src/index.ts"],
      "@shm/traefik": ["packages/traefik/src/index.ts"],
      "@shm/instances": ["packages/instances/src/index.ts"],
      "@shm/core": ["packages/core/src/index.ts"],
      "@shm/backup": ["packages/backup/src/index.ts"],
      "@shm/support": ["packages/support/src/index.ts"],
      "@shm/auth": ["packages/auth/src/index.ts"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "apps/*/src/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
